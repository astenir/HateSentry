# HateSentry local development environment.
# Copy to .env and adjust values for your machine.

# Required for bootstrapping the first admin user on a fresh database.
# Leave empty after the first admin is created.
ADMIN_BOOTSTRAP_TOKEN=

# Local-only default. Set a high-entropy secret for any shared environment.
APP_VERSION=dev
JWT_SECRET=dev-jwt-secret-change-me
SERVER_MODE=debug

# AI provider: openai or ollama.
AI_PROVIDER=openai

# OpenAI provider settings.
# Do not commit real API keys in .env files.
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama provider settings. Use COMPOSE_PROFILES=ollama with docker compose
# when you want Compose to start the local Ollama service.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Moderation policy defaults.
MODERATION_POLICY_VERSION=default-v1
MODERATION_REVIEW_THRESHOLD=0.4
MODERATION_BLOCK_THRESHOLD=0.75

# API-key client moderation rate limit.
MODERATION_CLIENT_RATE_LIMIT=60
MODERATION_CLIENT_RATE_WINDOW=1m

# Final-decision webhook retry worker.
MODERATION_WEBHOOK_RETRY_ENABLED=true
MODERATION_WEBHOOK_RETRY_INTERVAL=1m
MODERATION_WEBHOOK_RETRY_BATCH_SIZE=10
MODERATION_WEBHOOK_RETRY_MAX_ATTEMPTS=3

# Optional smoke workflow settings. These are consumed by
# scripts/smoke_moderation_workflow.py, not by the API container.
HATESENTRY_BASE_URL=http://localhost:8080
HATESENTRY_ADMIN_EMAIL=admin@example.com
HATESENTRY_ADMIN_PASSWORD=password123
HATESENTRY_ADMIN_BOOTSTRAP_TOKEN=
HATESENTRY_ADMIN_USERNAME=smoke-admin
HATESENTRY_POLICY_VERSION=default-v1

# Optional local infrastructure overrides.
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=hatesentry
DB_PASSWORD=hatesentry
DB_DATABASE=hatesentry
MYSQL_ROOT_PASSWORD=password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=detection_tasks
RABBITMQ_EXCHANGE=hatesentry
RABBITMQ_ROUTING_KEY=detection
