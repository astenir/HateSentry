# Copy this file outside the repository, replace every placeholder, and keep it private.
APP_VERSION=0.2.0
SERVER_MODE=release
JWT_SECRET=replace-with-at-least-32-random-characters

DB_USERNAME=hatesentry_app
DB_PASSWORD=replace-with-at-least-16-random-characters
DB_DATABASE=hatesentry
MYSQL_ROOT_PASSWORD=replace-with-at-least-16-random-characters

REDIS_PASSWORD=replace-with-at-least-16-random-characters

RABBITMQ_USERNAME=hatesentry_queue
RABBITMQ_PASSWORD=replace-with-at-least-16-random-characters

# Set only for the first administrator bootstrap. Clear it immediately afterward.
ADMIN_BOOTSTRAP_TOKEN=

AI_PROVIDER=openai
OPENAI_API_KEY=replace-with-a-real-provider-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

MODERATION_WEBHOOK_RETRY_ENABLED=true
MODERATION_WEBHOOK_RETRY_INTERVAL=1m
MODERATION_WEBHOOK_RETRY_BATCH_SIZE=10
MODERATION_WEBHOOK_RETRY_MAX_ATTEMPTS=3
